#include <bits/stdc++.h>
using namespace std;
class Book{
    string Title;
    string Author;
    string ISBN;
    public:
    Book(){
        this->Title = "";
        this->Author = "";
        this->ISBN = "";
    }
    Book(string &t, string &a, string &i){
        this->Title = t;
        this->Author = a;
        this->ISBN = i;
    }
    Book(Book &b){
        this->Title = b.Title;
        this->Author = b.Author;
        this->ISBN = b.ISBN;
    }
};

class Library{
    public:
    Book b[10];
    int n=0;
    bool addNewBook(string& title, string& author, string& isbn){
        this->b[n] = Book(title,author, isbn);
        n++;
        return true;
    }
    bool removeBooks(string& ISBN);
    
    void displayDetails(){
        for(int i=0;i<n;i++){
            cout<<b[i].Title<<" "<<b[i].Author<<" "<<b[i].ISBN<<endl;
        }
    }
};

bool Library::removeBooks(string &ISBN){
    for(int i=0;i<n;i++){
        if(b[i].ISBN==ISBN){
            b[i] = b[n-1];
            n--;
            return true;
        }
    }
    return false;
}
