#include <iostream>
using namespace std;

template <class T>
void bubbleSort(T arr[], int size) {

    for(int i = 0; i < size - 1; i++) {

        for(int j = 0; j < size - i - 1; j++) {

            if(arr[j] > arr[j + 1]) {

                T temp;

                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main() {

    int arr[] = {5, 1, 4, 2, 8};

    bubbleSort(arr, 5);

    cout << "Sorted Array:\n";

    for(int i = 0; i < 5; i++) {
        cout << arr[i] << " ";
    }

    return 0;
}
