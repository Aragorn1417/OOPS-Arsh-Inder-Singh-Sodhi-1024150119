#include <iostream>
using namespace std;

template <class T>
class Stack {

private:
    T arr[5];
    int top;

public:

    Stack() {
        top = -1;
    }

    void push(T value) {

        if(top == 4) {
            cout << "Stack Overflow\n";
            return;
        }

        top++;

        arr[top] = value;
    }

    void pop() {

        if(top == -1) {
            cout << "Stack Underflow\n";
            return;
        }

        cout << "Popped Element = " << arr[top] << endl;

        top--;
    }
};

int main() {

    Stack<int> s;

    s.push(10);
    s.push(20);

    s.pop();

    return 0;
}
