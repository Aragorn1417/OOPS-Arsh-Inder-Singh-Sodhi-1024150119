#include <iostream>
using namespace std;

template <class T>
class Array {

private:
    T arr[5];

public:

    void input() {

        cout << "Enter 5 Elements:\n";

        for(int i = 0; i < 5; i++) {
            cin >> arr[i];
        }
    }

    void display() {

        cout << "Array Elements:\n";

        for(int i = 0; i < 5; i++) {
            cout << arr[i] << " ";
        }
    }
};

int main() {

    Array<int> obj;

    obj.input();

    obj.display();

    return 0;
}
