#include <iostream>
using namespace std;

class Time {
    int h;
    int m;
    int s;

public:
    Time(int hour = 0, int minute = 0, int second = 0) {
        h = hour;
        m = minute;
        s = second;
    }

    Time operator+(const Time& t) {
        Time temp;

        temp.s = s + t.s;
        temp.m = m + t.m + temp.s / 60;
        temp.s = temp.s % 60;
        temp.h = h + t.h + temp.m / 60;
        temp.m = temp.m % 60;

        return temp;
    }

    void show() {
        cout << h << " hours " << m << " minutes " << s << " seconds" << endl;
    }
};

int main() {
    Time t1(5, 15, 34), t2(9, 53, 58), t3;
    t3 = t1 + t2;
    t3.show();

    return 0;
}
