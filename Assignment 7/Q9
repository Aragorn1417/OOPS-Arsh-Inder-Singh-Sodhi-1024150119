#include <iostream>
#include <vector>
using namespace std;

class Numbers {
    vector<int> values;

public:
    void operator()(int n) {
        values.clear();

        cout << "Enter " << n << " numbers:" << endl;
        for (int i = 0; i < n; i++) {
            int x;
            cin >> x;
            values.push_back(x);
        }
    }

    void display() {
        cout << "You entered: ";
        for (int i = 0; i < values.size(); i++) {
            cout << values[i] << " ";
        }
        cout << endl;
    }
};

int main() {
    Numbers obj;
    int n;

    cout << "How many numbers do you want to enter? ";
    cin >> n;

    obj(n);
    obj.display();

    return 0;
}
