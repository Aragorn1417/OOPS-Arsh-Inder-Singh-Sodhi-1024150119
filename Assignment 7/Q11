#include <iostream>
using namespace std;

class Test {
    int meters;
    int centimeters;

public:
    Test(float value = 0) {
        int totalCentimeters = static_cast<int>(value * 100 + 0.5f);
        meters = totalCentimeters / 100;
        centimeters = totalCentimeters % 100;
    }

    void show() {
        cout << "Meters: " << meters << endl;
        cout << "Centimeters: " << centimeters << endl;
    }
};

int main() {
    float distance;

    cout << "Enter distance in meters: ";
    cin >> distance;

    Test t = distance;
    t.show();

    return 0;
}
