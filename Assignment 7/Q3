#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;

double area(double side) {
    return (sqrt(3) / 4) * side * side;
}

double area(double base, double height) {
    return 0.5 * base * height;
}

double area(double side1, double side2, double base) {
    double s = (side1 + side2 + base) / 2;
    return sqrt(s * (s - side1) * (s - side2) * (s - base));
}

int main() {
    cout << fixed << setprecision(2);

    double rightBase = 6;
    double rightHeight = 4;
    double equilateralSide = 5;
    double isoscelesSide1 = 5;
    double isoscelesSide2 = 5;
    double isoscelesBase = 6;

    cout << "Area of right angle triangle: " << area(rightBase, rightHeight) << endl;
    cout << "Area of equilateral triangle: " << area(equilateralSide) << endl;
    cout << "Area of isosceles triangle: " << area(isoscelesSide1, isoscelesSide2, isoscelesBase) << endl;

    return 0;
}
