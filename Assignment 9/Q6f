#include <iostream>
#include <fstream>
using namespace std;

int main() {

    fstream file("hello.txt", ios::out | ios::in);

    string text = "HelloWorld";

    // Write characters and display tellp()
    for(int i = 0; i < text.length(); i++) {

        file.put(text[i]);

        cout << "Position after writing ";
        cout << text[i] << " = ";
        cout << file.tellp() << endl;
    }

    // Replace "World" with "C++"
    file.seekp(5);

    file << "C++";

    file.close();

    cout << "Replacement done.";

    return 0;
}
